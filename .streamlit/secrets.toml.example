# 이 파일을 복사해서 .streamlit/secrets.toml 로 저장하고 값을 채우세요.
# secrets.toml은 .gitignore에 포함되어 git에 올라가지 않습니다.
# OAuth 클라이언트 발급 / refresh_token 얻는 방법은 SETUP.md 참고.

app_password = "parking2026"

# scripts/get_refresh_token.py 실행 결과를 그대로 붙여넣으세요.
[google_oauth]
client_id = "YOUR_OAUTH_CLIENT_ID"
client_secret = "YOUR_OAUTH_CLIENT_SECRET"
refresh_token = "YOUR_REFRESH_TOKEN"

[drive_folders]
audio = "GOOGLE_DRIVE_AUDIO_FOLDER_ID"
viz = "GOOGLE_DRIVE_VIZ_FOLDER_ID"
docs = "GOOGLE_DRIVE_DOCS_FOLDER_ID"

[google_sheets]
spreadsheet_id = "GOOGLE_SPREADSHEET_ID"
